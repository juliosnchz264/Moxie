---
import type { Block } from '@moxie/core';

interface Props {
  block: Block;
  className: string;
}

const colsClass: Record<2 | 3 | 4, string> = {
  2: 'grid-cols-2',
  3: 'grid-cols-3',
  4: 'grid-cols-4',
};

const { block, className } = Astro.props as Props;
const props = (block.props ?? {}) as {
  columns?: 2 | 3 | 4;
  items?: { src: string; alt?: string }[];
};
const cols = colsClass[props.columns ?? 3];
const items = props.items ?? [];
---

{items.length === 0 ? (
  <div class={className}></div>
) : (
  <div class={`${className} grid ${cols} gap-2`}>
    {items.map((it) => (
      <img
        src={it.src}
        alt={it.alt ?? ''}
        loading="lazy"
        class="w-full aspect-square object-cover rounded"
      />
    ))}
  </div>
)}
