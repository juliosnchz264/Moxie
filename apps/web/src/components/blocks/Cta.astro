---
import type { Block } from '@moxie/core';

interface Props {
  block: Block;
  className: string;
}

const { block, className } = Astro.props as Props;
const props = (block.props ?? {}) as {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
};
---

<section class={className}>
  <div class="flex flex-col items-center gap-3">
    <h2 class="text-3xl font-bold text-center">{props.title ?? ''}</h2>
    {props.subtitle ? <p class="text-center max-w-xl">{props.subtitle}</p> : null}
    <a
      href={props.ctaHref ?? '#'}
      class="inline-flex items-center rounded bg-blue-600 text-white px-5 py-2.5 text-sm font-medium mt-2 hover:bg-blue-700"
    >
      {props.ctaLabel ?? 'Learn more'}
    </a>
  </div>
</section>
