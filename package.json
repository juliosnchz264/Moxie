{
  "name": "moxie",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant visual CMS — free-tier, versioned block contract, token-based styling",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "^9 || ^10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=backend",
    "dev:studio": "turbo run dev --filter=editor",
    "dev:web": "turbo run dev --filter=public-site",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:int": "turbo run test:int",
    "test:e2e": "turbo run test:e2e",
    "generate:types": "turbo run generate:types",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
